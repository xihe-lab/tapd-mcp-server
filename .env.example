# TAPD MCP Server 环境变量配置
# 在 TAPD 开放平台申请凭证: https://open.tapd.cn

# ============ 认证方式（二选一）============

# 方式一: Access Token 认证（推荐）
TAPD_ACCESS_TOKEN=your_access_token

# 方式二: Basic Auth 认证
# TAPD_API_USER=your_company_id
# TAPD_API_PASSWORD=your_api_password

# ============ 默认项目空间 ============

# 默认 workspace_id，多数工具的必填参数
TAPD_DEFAULT_WORKSPACE_ID=your_workspace_id
